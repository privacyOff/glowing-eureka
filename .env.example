APP_ENV=development

REQUIRE_GEMINI=false

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/customer_support

GEMINI_API_KEY=

WHISPER_MODEL=base

EMBEDDING_MODEL=all-MiniLM-L6-v2

SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment

SENTIMENT_POSITIVE_THRESHOLD=0.05
SENTIMENT_NEGATIVE_THRESHOLD=-0.05

NER_MODEL=en_core_web_md

ENABLE_CUSTOM_ENTITIES=true
ENABLE_REGEX_ENTITIES=true

CLASSIFICATION_MODEL=facebook/bart-large-mnli
CLASSIFICATION_THRESHOLD=0.60

MAX_AUDIO_DURATION_MINUTES=60

SUPPORTED_AUDIO_FORMATS=wav,mp3,m4a,flac

FAISS_PATH=data/embeddings
FAISS_INDEX_FILE=data/embeddings/faiss.index
FAISS_METADATA_FILE=data/embeddings/metadata.pkl
FAISS_INDEX_METADATA_FILE=data/embeddings/index_metadata.json

SEARCH_TOP_K=5

LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_PATH=logs/application.log